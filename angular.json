{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "demo-microfrontendA20": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss",
          "type": "component"
        },
        "@schematics/angular:service": {
          "type": "service"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "bocc",
      "architect": {
        "build": {
          "builder": "@angular-architects/native-federation:build",
          "options": {
            "target": "demo-microfrontendA20:esbuild:development"
          },
          "configurations": {
             "local": {
              "target": "demo-microfrontendA20:esbuild:local"
            },
            "development": {
              "target": "demo-microfrontendA20:esbuild:development"
            },
            "qa": {
              "target": "demo-microfrontendA20:esbuild:qa"
            },
            "production": {
              "target": "demo-microfrontendA20:production"
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-architects/native-federation:build",
          "options": {
            "target": "demo-microfrontendA20:serve-original:development",
            "rebuildDelay": 500,
            "dev": true
          },
          "configurations": {
            "local": {
              "target": "demo-microfrontendA20:serve-original:local"
            },
            "development": {
              "target": "demo-microfrontendA20:serve-original:development"
            },
            "qa": {
              "target": "demo-microfrontendA20:serve-original:qa"
            },
            "production": {
              "target": "demo-microfrontendA20:serve-original:production"
            }
          },
           "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n"
        },
        "test": {
           "builder": "@angular/build:karma",
          "options": {
            "codeCoverage": true,
            "karmaConfig": "karma.conf.js",
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "tsconfig.spec.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [
              "src/styles.scss"
            ],
            "scripts": []
          }
        },
        "esbuild": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist",
            "browser": "src/main.ts",
            "polyfills": [
              "zone.js",
              "es-module-shims"
            ],
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [
              "src/styles.scss"
            ]
          },
          "configurations": {
            "local": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.ts"
                }
              ],
              "sourceMap": true,
              "optimization": false
            },
            "development": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.development.ts"
                }
              ],
              "sourceMap": true,
              "optimization": false
            },
            "qa": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.qa.ts"
                }
              ],
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "600kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "150kB",
                  "maximumError": "150kB"
                }
              ],
              "outputHashing": "all"
            },
            "production": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.production.ts"
                }
              ],
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "600kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "150kB",
                  "maximumError": "150kB"
                }
              ],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false
            }
          },
          "defaultConfiguration": "development"
        },
        "serve-original": {
          "builder": "@angular/build:dev-server",
          "configurations": {
              "local": {
              "buildTarget": "demo-microfrontendA20:esbuild:local"
            },
            "development": {
              "buildTarget": "demo-microfrontendA20:esbuild:development"
            },
            "qa": {
              "buildTarget": "demo-microfrontendA20:esbuild:qa"
            },
            "production": {
              "buildTarget": "demo-microfrontendA20:esbuild:production"
            }
          },
          "defaultConfiguration": "development",
          "options": {
            "port": 4201
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "src/**/*.ts",
              "src/**/*.html"
            ]
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false,
    "schematicCollections": [
      "angular-eslint"
    ]
  }
}
